# Trading Mode: paper or live
TRADING_MODE=paper

# Binance API (leave empty for paper trading)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET=false

# Database
# Use 'postgres' as hostname when running via Docker Compose;
# use 'localhost' when running outside Docker.
DATABASE_URL=postgresql+asyncpg://trader:trading123@postgres:5432/tradingbot

# Redis
# Use 'redis' as hostname when running via Docker Compose;
# use 'localhost' when running outside Docker.
REDIS_URL=redis://redis:6379

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Initial Capital (paper trading)
INITIAL_CAPITAL=50.0

# Risk Parameters
RISK_PER_TRADE=0.005
DAILY_DRAWDOWN_LIMIT=0.03
MAX_OPEN_POSITIONS=5
TAKE_PROFIT_PCT=0.004
STOP_LOSS_PCT=0.0025

# Assets to monitor (BTCUSDT is always loaded for regime detection)
MONITORED_SYMBOLS=SOLUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,BNBUSDT

# Max daily losses before pausing trading
MAX_DAILY_LOSSES=5

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# Log level
LOG_LEVEL=INFO
